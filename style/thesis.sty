%% ===== ソースコード =====
\usepackage{algorithm}          % アルゴリズムのフロート
\usepackage[noend]{algpseudocode} % 擬似コード
\usepackage{listings,jvlisting} % ソースコードの出力（jvlistingで和文対応）
\lstset{
    language=Python,            % 既定のプログラミング言語（各listingで上書き可）
    basicstyle=\ttfamily\small,
    commentstyle=\itshape\color{gray},
    keywordstyle=\bfseries\color{blue!80!black},
    stringstyle=\color{red!70!black},
    numbers=left,               % 左に行番号
    numberstyle=\ttfamily\small\color{gray},
    numbersep=10pt,
    xleftmargin=20pt,
    frame=single,               % コードを枠で囲む
    framesep=5pt,
    backgroundcolor=\color[gray]{0.96},
    showstringspaces=false,
    tabsize=4,
    breaklines=true,            % 長い行は折り返す
}
\renewcommand{\lstlistingname}{ソースコード}

%% ===== URL・ハイパーリンク =====
\usepackage{url}                            % URLの出力
