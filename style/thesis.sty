%% ===== 定理・定義環境（章ごとに採番） =====
\theoremstyle{definition}
\newtheorem{definition}{定義}[chapter]
\newtheorem{example}{例}[chapter]
\theoremstyle{plain}
\newtheorem{theorem}{定理}[chapter]
\newtheorem{lemma}{補題}[chapter]
\renewcommand{\proofname}{証明}

%% ===== フロート名の和訳 =====
\renewcommand{\listalgorithmname}{アルゴリズム目次}
\floatname{algorithm}{アルゴリズム}

\makeatletter

%% ===== ヘッダー・フッター =====
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\nouppercase{\leftmark}}   % 左上：章
\fancyhead[R]{\nouppercase{\rightmark}}  % 右上：節
\cfoot{{\ttfamily \thepage}}             % 中央下：ページ番号
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\chaptermark}[1]{\markboth{第\ \thechapter\ 章\ \ #1}{}}
\renewcommand{\sectionmark}[1]{\markright{\thesection\ \ #1}{}}
% 章扉など plain ページにもヘッダ罫線を出さない（既定動作）
\fancypagestyle{plain}{%
  \fancyhf{}%
  \cfoot{{\ttfamily \thepage}}%
  \renewcommand{\headrulewidth}{0pt}%
}

%% ===== 表紙用の追加情報コマンド =====
% 論文種別
\def\@thesistype{卒業論文}
\newcommand{\thesistype}[1]{\def\@thesistype{#1}}
% サブタイトル
\def\@subtitle{}
\newcommand{\subtitle}[1]{\def\@subtitle{#1}}
% 指導教員
\def\@supervisor{}
\newcommand{\supervisor}[1]{\def\@supervisor{#1}}
% 所属（学部・学科・専攻など）
\def\@affiliation{}
\newcommand{\affiliation}[1]{\def\@affiliation{#1}}

%% ===== 表紙 =====
\renewcommand{\maketitle}{%
  \begin{titlepage}%
    \thispagestyle{empty}%
    \vspace*{20truemm}%
    \begin{center}{\Large \@thesistype}\end{center}%
    \vspace*{35truemm}%
    \begin{center}%
      {\LARGE\bfseries\gtfamily \@title \par}%
      \ifx\@subtitle\empty\else
        \vspace{6mm}%
        {\Large\gtfamily \@subtitle \par}%
      \fi
    \end{center}%
    \vspace*{\fill}%
    \begin{center}{\Large \@author \par}\end{center}%
    \ifx\@supervisor\empty\else
      \vspace{6mm}%
      \begin{center}{\large 指導教員\quad \@supervisor \par}\end{center}%
    \fi
    \vspace{12mm}%
    \ifx\@affiliation\empty\else
      \begin{center}{\Large \@affiliation \par}\end{center}%
      \vspace{8mm}%
    \fi
    \begin{center}{\large \@date \par}\end{center}%
    \vspace*{20truemm}%
  \end{titlepage}%
}

%% ===== 下書きモード =====
% \ThisIsDraft を本文冒頭に記述すると，全ページに「DRAFT」の透かしと
% 左上にビルド日時のバージョン情報が入る．提出時には削除すること．
\newcommand{\ThisIsDraft}{%
    \AddToShipoutPictureFG{%
      % バージョン情報（左上の余白）
      \AtPageUpperLeft{%
        \hspace*{10mm}%
        \raisebox{-13mm}[0pt][0pt]{%
          \textcolor{red}{%
            \ttfamily\footnotesize
            Ver.\number\year-%
            \ifthenelse{\month<10}{0\number\month}{\number\month}-%
            \ifthenelse{\day<10}{0\number\day}{\number\day}%
          }%
        }%
      }%
      % DRAFT（右上の余白・本文にかからない位置）
      \AtPageUpperLeft{%
        \makebox[\paperwidth][r]{%
          \raisebox{-13mm}[0pt][0pt]{%
            \textcolor{red!45}{\sffamily\bfseries\Large DRAFT}%
          }%
          \hspace*{12mm}%
        }%
      }%
    }%
}

\makeatother
