% 行間を15%縮める
\AtBeginDocument{\renewcommand{\baselinestretch}{0.85}\normalsize}

% 指導教員名を保存するための内部変数
\def\@supervisor{}%
\newcommand{\supervisor}[1]{%
  \def\@supervisor{#1}%
}

% サブタイトルを保存するための内部変数
\def\@subtitle{}%
\newcommand{\subtitle}[1]{%
  \def\@subtitle{#1}%
}

% 複数著者を \and でつなぐときに、改行ではなく横に並べる
\def\and{\unskip\hspace{2em}} % 間隔は好みで調整
\renewcommand{\maketitle}{%
  \twocolumn[%
    \begin{center}%
      \vspace*{-10mm}% タイトルを少し上に
      {\LARGE\bfseries\gtfamily \@title \par}%
      \ifx\@subtitle\empty\else
        \vspace{0.3em}%
        {\large\gtfamily \@subtitle \par}%
      \fi
      \vspace{0.8em}%
      {\large \@author \par}%
      {\normalsize \textbf{指導教員}\ \@supervisor \par}%
    \end{center}%
  ]%
}

\renewcommand{\section}{%
  \@startsection{section}{1}{\z@}%
    {1.5ex plus 0.5ex minus 0.5ex}% 上：やや詰め
    {0.8ex plus 0.2ex}% 下：少し詰め\textbf{}
    {\large\bfseries\gtfamily}%
}

% 小節見出し（subsection）も少しタイトに
\renewcommand{\subsection}{%
  \@startsection{subsection}{2}{\z@}%
    {1.5ex plus 0.3ex minus 0.2ex}% ← 正の値に
    {0.5ex plus 0.1ex}%
    {\normalsize\gtfamily}%
}

% 下書きの時にバージョン情報と透かしを出すようにする
\newcommand{\ThisIsDraft}{%
    \pagestyle{plain}%
    \AddToShipoutPictureFG{%
      % 左上にバージョン情報
      \AtPageUpperLeft{%
        \hspace*{10mm}%
        \raisebox{-10mm}[0pt][0pt]{%
        \textcolor{red}{%
          \ttfamily\footnotesize
          Ver.\number\year-%
          \ifthenelse{\month<10}{0\number\month}{\number\month}-%
          \ifthenelse{\day<10}{0\number\day}{\number\day}-%
          \ifthenelse{\hour<10}{0\number\the\hour}{\number\the\hour}%
          \ifthenelse{\minute<10}{0\the\minute}{\the\minute}%
        }%
        }%
      }%
      % 右上にDRAFT透かし
      \AtPageUpperLeft{%
        \hspace*{\dimexpr\paperwidth-35mm\relax}%
        \raisebox{-18mm}[0pt][0pt]{%
          \rotatebox{-30}{%
            \textcolor{gray!30}{%
              \sffamily\bfseries\fontsize{24pt}{24pt}\selectfont DRAFT%
            }%
          }%
        }%
      }%
    }%
}

